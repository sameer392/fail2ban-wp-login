# Fail2ban log rotation - prevents unbounded growth (e.g. 200MB+)
# Installed by install.sh / update.sh from logrotate.d/ to /etc/logrotate.d/fail2ban
# Rotate when log reaches 50MB or weekly; keep 4 archives compressed
/var/log/fail2ban.log {
    missingok
    notifempty
    size 50M
    weekly
    rotate 4
    compress
    delaycompress
    postrotate
        /usr/bin/fail2ban-client flushlogs >/dev/null 2>&1 || true
    endscript
}
